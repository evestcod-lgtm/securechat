PORT=3000
XKEY=ChangeMe-To-Any-Long-Random-String-123!
ADMIN_PASSWORD=ChangeMeToYourOwnPassword

# Для автообновления адреса сервера на GitHub (см. patches/update-server-url.sh)
# GITHUB_TOKEN — Personal Access Token (classic) с правами "repo", создать на
# github.com → фото профиля → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=
GITHUB_REPO=evestcod-lgtm/securechat
GITHUB_BRANCH=main
